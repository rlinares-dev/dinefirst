# ============================================
# DineFirst — Variables de Entorno
# ============================================
# Copiar a .env.local y rellenar los valores

# --- Supabase (REQUERIDO para producción) ---
# Crear proyecto en https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[tu-proyecto].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe (Fase 2 — opcional por ahora) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# --- Twilio WhatsApp (Fase 3 — producción) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Resend Email (Fase 3) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@dinefirst.com

# --- n8n Webhook (modo test notificaciones) ---
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# --- Google OAuth (configurar en Supabase Dashboard → Auth → Providers) ---
# No requiere env vars aquí — se configura directamente en Supabase
